{
  "name": "story-map-spa",
  "main": "docs/index.html",
  "build_command": "npm run build",
  "build_output_dir": "docs",
  "routes": [
    {
      "src": "/stories/(.*)",
      "dest": "/index.html"
    },
    {
      "src": "/add/(.*)",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
